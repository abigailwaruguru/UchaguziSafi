# =============================================================================
# UCHAGUZI SAFI — Production Environment Variables
# Copy to .env on your production server and fill in real values.
# NEVER commit this file with real secrets to Git.
# =============================================================================

# --- Application ---
APP_NAME=Uchaguzi Safi
APP_VERSION=0.1.0
APP_DESCRIPTION=Campaign Finance Transparency Tool — Kenya 2027 Elections
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=warning

# --- Database (PostgreSQL) ---
# Railway provides this automatically as DATABASE_URL when you add a Postgres plugin.
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/uchaguzi_safi
DATABASE_URL_SYNC=postgresql://user:password@host:5432/uchaguzi_safi

# --- Authentication (JWT) ---
# CRITICAL: Generate a strong random key. Run this in Python:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE-ME-TO-A-REAL-SECRET-KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- CORS ---
# Your production frontend URL. No trailing slash.
# If frontend is served from the same domain (Railway single-service), use:
#   ALLOWED_ORIGINS=https://your-app.up.railway.app
# If frontend is on Vercel separately:
#   ALLOWED_ORIGINS=https://uchaguzi-safi.vercel.app,https://your-custom-domain.co.ke
ALLOWED_ORIGINS=https://your-app.up.railway.app

# --- Mapbox (Frontend) ---
# Only needed if deploying frontend separately (Vercel).
# Get a token at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your_production_mapbox_token

# --- Frontend API URL ---
# If frontend is on Vercel pointing to Railway backend:
VITE_API_URL=https://your-backend.up.railway.app/api/v1
# If both are on Railway (same service), use:
# VITE_API_URL=/api/v1

# --- Kenya-Specific Constants (ECF Act Cap. 7A) ---
DEFAULT_CURRENCY=KES
CONTRIBUTION_DISCLOSURE_THRESHOLD=20000
SINGLE_SOURCE_CONTRIBUTION_CAP_PERCENT=20
MAX_FINE_KES=2000000

# --- File Uploads ---
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=/app/uploads

# --- Railway-Specific ---
# Railway sets PORT automatically — do NOT set it manually.
# Railway sets RAILWAY_ENVIRONMENT automatically.
# WEB_CONCURRENCY controls uvicorn worker count:
WEB_CONCURRENCY=2
