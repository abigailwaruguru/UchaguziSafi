# =============================================================================
# UCHAGUZI SAFI — Backend Dev Environment
# Used when running the backend LOCALLY (outside Docker).
# When running inside Docker, docker-compose.yml injects these directly.
# =============================================================================

# --- Database (PostgreSQL) ---
# Use localhost when running without Docker (requires Postgres running locally).
# Change host to "postgres" if running inside Docker and overriding compose env.
DATABASE_URL=postgresql+asyncpg://postgres:%40b1g%401lgr%40c3@localhost:5432/uchaguzi_safi
DATABASE_URL_SYNC=postgresql://postgres:%%40b1g%%401lgr%%40c3@localhost:5432/uchaguzi_safi

# --- App ---
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=debug

# --- Auth ---
SECRET_KEY=dev-secret-key-not-for-production-change-me

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- File Uploads ---
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=./uploads
