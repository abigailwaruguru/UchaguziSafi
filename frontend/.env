# =============================================================================
# UCHAGUZI SAFI — Frontend Dev Environment
# Copy of env.example with dev defaults filled in.
# =============================================================================

# API Base URL — proxied via Vite (see vite.config.js proxy settings)
VITE_API_URL=/api/v1

# Mapbox Access Token — required for M2 Taswira (County Spending Map)
# Get a free token at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# App metadata
VITE_APP_NAME=Uchaguzi Safi
VITE_APP_VERSION=0.1.0
