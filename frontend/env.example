# =============================================================================
# UCHAGUZI SAFI — Frontend Environment Variables
# Copy to .env and fill in values before running
# =============================================================================

# API Base URL — points to FastAPI backend
# In development: proxied via Vite (see vite.config.js)
# In production: set to the deployed API URL
VITE_API_URL=/api/v1

# Mapbox Access Token — required for M2 Taswira (County Spending Map)
# Get a free token at https://account.mapbox.com/access-tokens/
# The map displays Kenya's 47 counties with campaign spending overlays
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Application metadata
VITE_APP_NAME=Uchaguzi Safi
VITE_APP_VERSION=0.1.0
